# --- 사용자 요청 제외 항목 ---

# 데이터 폴더 (대용량 파일 포함)
data/

# 학습 로그 및 체크포인트 폴더
runs/

# 예측 결과 출력 폴더 (pred_scene_으로 시작하는 모든 폴더 제외)
pred_scene_*/

# 백그라운드 실행 로그 파일
nohup.out


# --- Python 기본 제외 항목 (권장) ---

# 파이썬 캐시 파일
__pycache__/
*.py[cod]
*$py.class

# 가상환경 폴더 (만약 venv나 env를 쓰신다면)
venv/
env/

# 에디터 및 OS 설정 파일
.vscode/
.idea/
.DS_Store